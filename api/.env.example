# Port the NestJS API listens on
PORT=3001

# MongoDB Atlas (or other Mongo) connection string
MONGODB_URI=

# Cloudflare R2 (S3-compatible) - account ID, from the Cloudflare dashboard
R2_ACCOUNT_ID=

# Cloudflare R2 - access key ID for an R2 API token
R2_ACCESS_KEY_ID=

# Cloudflare R2 - secret access key for the same R2 API token
R2_SECRET_ACCESS_KEY=

# Cloudflare R2 - name of the bucket objects are uploaded to
R2_BUCKET_NAME=

# Public base URL objects are served from (custom domain or the R2.dev public URL, once enabled on the bucket)
R2_PUBLIC_URL_BASE=
